{
  "manifest_version": 3,
  "name": "Agent Withdrawal Automation",
  "version": "1.0.0",
  "description": "Automates agent.upi9.pro withdrawal flow: login, view details, save to DB, call GatewayHub, approve/reject based on status",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://agent.upi9.pro/*",
    "https://api-prod.gatewayhub.live/*",
    "https://autoflow-ce-api.botauto.online/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Agent Withdrawal Automation"
  },
  "content_scripts": [
    {
      "matches": ["https://agent.upi9.pro/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
